# The Simulation Space — API Keys
# Copy this file to .env.local and fill in your keys.

# Required — CesiumJS 3D globe (free: https://cesium.com/ion)
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Required — AI terminal + simulation LLM (https://ai.google.dev)
GEMINI_API_KEY=

# Simulation engine — knowledge graphs (https://getzep.com)
ZEP_API_KEY=

# Data layers (optional — each enables specific layers)
AISSTREAM_API_KEY=          # Live ship tracking (https://aisstream.io)
WINDY_WEBCAM_API_KEY=       # Global webcam feeds (https://api.windy.com)
ACLED_API_KEY=              # Armed conflict data (https://acleddata.com)
ACLED_EMAIL=                # ACLED account email
FRED_API_KEY=               # Federal Reserve economic data (https://fred.stlouisfed.org)
EIA_API_KEY=                # Energy data (https://eia.gov/opendata)
RELIEFWEB_APPNAME=the-simulation-space  # Humanitarian data (free, no key)

# AI & Research (optional)
NVIDIA_API_KEY=             # Nemotron supply chain research (https://build.nvidia.com)
BRAVE_SEARCH_KEY=           # Web search for terminal (https://brave.com/search/api)
